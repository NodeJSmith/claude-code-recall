{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'command -v ccrecall-setup >/dev/null 2>&1 && ccrecall-setup || true'",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash -c 'command -v ccrecall-onboarding >/dev/null 2>&1 && ccrecall-onboarding || true'",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash -c 'command -v ccrecall-context >/dev/null 2>&1 && ccrecall-context || true'",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'command -v ccrecall-clear-handoff >/dev/null 2>&1 && ccrecall-clear-handoff || true'",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'command -v ccrecall-sync >/dev/null 2>&1 && ccrecall-sync || true'",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
